# Database
DB_TYPE=sqlite
DB_PATH=/scripts/library_history.db
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASS=

# Radarr
RADARR_URL=http://YOUR_NAS_IP:7878
RADARR_API_KEY=

# Sonarr
SONARR_URL=http://YOUR_NAS_IP:8989
SONARR_API_KEY=

# Jellyseerr
# API key location: Jellyseerr UI → Settings → General → API Key
# API docs: http://YOUR_JELLYSEERR_HOST:5055/api-docs
# Auth method: HTTP header X-Api-Key: <key>
# Used for: request tracking by user (requestedBy.plexUsername, media.tmdbId, isAutoRequest)
JELLYSEERR_URL=http://YOUR_JELLYSEERR_HOST:5055
JELLYSEERR_API_KEY=

# IMDb flat files (mounted into container at /data/imdb)
IMDB_BASICS_PATH=/data/imdb/title_basics.tsv
IMDB_RATINGS_PATH=/data/imdb/title_ratings.tsv

# Display defaults
DEFAULT_TAB=movies
ROWS_PER_TABLE=10
